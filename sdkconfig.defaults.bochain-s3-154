# BoChain Xiaozhi ESP32-S3 + ST7789 1.54 inch 240x240
# This file is only for CI/release builds. It fixes the board and LCD choice.

CONFIG_IDF_TARGET_ESP32S3=y

# Board: main/boards/bread-compact-wifi-lcd
CONFIG_BOARD_TYPE_BREAD_COMPACT_WIFI_LCD=y

# LCD: ST7789 240x240, 1.54 inch
CONFIG_LCD_ST7789_240X240=y

# Keep Chinese UI assets/language by default
CONFIG_LANGUAGE_ZH_CN=y
CONFIG_FLASH_DEFAULT_ASSETS=y

# Hardware defaults for common ESP32-S3 N16R8 modules
CONFIG_ESPTOOLPY_FLASHSIZE_16MB=y
CONFIG_ESPTOOLPY_FLASHMODE_QIO=y
CONFIG_ESP_DEFAULT_CPU_FREQ_MHZ_240=y
CONFIG_SPIRAM=y
CONFIG_SPIRAM_MODE_OCT=y
CONFIG_SPIRAM_SPEED_80M=y
CONFIG_SPIRAM_MALLOC_ALWAYSINTERNAL=2048
CONFIG_SPIRAM_MALLOC_RESERVE_INTERNAL=98304
CONFIG_SPIRAM_MEMTEST=n
CONFIG_MBEDTLS_EXTERNAL_MEM_ALLOC=y
